#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "../s21_string.h"

#test s21_strtok_test_1
int n=4;
char str1[] = "_afga ___aers@asr___sweer__";
char str2[] = "_afga ___aers@asr___sweer__"; 
const char vp[] = "_ ! @";

char *token = s21_strtok(str1, vp);
char *token_etalon = strtok(str2, vp);
ck_assert_pstr_eq(token, token_etalon);

for (int i = 0; i < n; i++) {
  token = s21_strtok(s21_NULL, vp);
  token_etalon = strtok(s21_NULL, vp);
  ck_assert_pstr_eq(token, token_etalon);
  }

