#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "../s21_string.h"

#test s21_strcspn_test_1
char str1[] ="There is a destination string for checking!!!!";
char str2[] =" ";  
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);

#test s21_strcspn_test_2
char str1[] ="There is a destination string for checking!!!!";
char str2[] ="";  
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);

#test s21_strcspn_test_3
char str1[] ="";
char str2[] ="";  
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);

#test s21_strcspn_test_4
char str1[] =" ";
char str2[] =" ";  
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);

#test s21_strcspn_test_5
char str1[] ="\0";
char str2[] =" ";  
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);

#test s21_strcspn_test_6
char str1[] ="";
char str2[] ="\0 ";
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);

#test s21_strcspn_test_7
char str1[] ="@#$%^&*()1234567890";
char str2[] ="!";
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);

#test s21_strcspn_test_8
char str1[] ="@#$%^&*()1234567890";
char str2[] ="^";
size_t result = s21_strcspn(str1, str2);
size_t result_etalon = strcspn(str1, str2);
ck_assert_uint_eq(result, result_etalon);
