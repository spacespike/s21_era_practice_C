#include <stdio.h>
#include <stdlib.h>
#include <string.h>

#include "../s21_string.h"

#test s21_strncmp_test_1
char str1[] ="There is a destination string for checking!!!!";
char str2[] ="There is a destination string for checking!!!!";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_2
char str1[] ="There is a destination string..";
char str2[] ="There is a destination string for checking!!!!";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_3
char str1[] ="There is a destination string for checking!!!!";
char str2[] ="There is a destination string..";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_4
char str1[] ="";
char str2[] ="";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_5
char str1[] ="There is a destination string for checking!!!!";
char str2[] ="There is a destination string \0..";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_6
char str1[] ="There is a destination string\0 for checking!!!!";
char str2[] ="There is a destination string..";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_7
char str1[] ="There is a destination string\0 for checking!!!!";
char str2[] ="There is a destination string\0 ..";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);


#test s21_strncmp_test_8
char str1[] ="!@#$%^&*()*(&%#%@$#!@)";
char str2[] ="!@#$%^&*()*   (&%#%@$#!@)";  
s21_size_t n = 10;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_9
char str1[] ="!@#$%^&*()*(&%#%@$#!@)";
char str2[] ="!@#$%^&*()*   (&%#%@$#!@)";  
s21_size_t n = 0;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
ck_assert_int_eq(result, result_etalon);

#test s21_strncmp_test_10
char str1[] ="";
char str2[] ="";  
s21_size_t n = 0;
int result = s21_strncmp(str1, str2, n);
int result_etalon = strncmp(str1, str2, n);
