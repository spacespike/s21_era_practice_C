#include <stdio.h>
#include <string.h>
#include "../s21_string.h"

#test s21_strlen_test_1
char str1[] ="There is a destination string for checking!!!!";
size_t result = s21_strlen(str1);
size_t result_etalon = strlen(str1);
ck_assert_uint_eq(result, result_etalon);

#test s21_strlen_test_2
char str1[] ="There is a destination\0 string for checking!!!!";
size_t result = s21_strlen(str1);
size_t result_etalon = strlen(str1);
ck_assert_uint_eq(result, result_etalon);

#test s21_strlen_test_3
char str1[] ="";
size_t result = s21_strlen(str1);
size_t result_etalon = strlen(str1);
ck_assert_uint_eq(result, result_etalon);

#test s21_strlen_test_4
char str1[] = " _aaa _bbb_ ccc__  312613argaGH;gn46q1346q1463 !@#$%^&*() 1234567890 ";
size_t result = s21_strlen(str1);
size_t result_etalon = strlen(str1);
ck_assert_uint_eq(result, result_etalon);

#test s21_strlen_test_5
char str1[] = "\0";
size_t result = s21_strlen(str1);
size_t result_etalon = strlen(str1);
ck_assert_uint_eq(result, result_etalon);

#test s21_strlen_test_6
char str1[] = "\0\0\0\0\0\0\0\0";
size_t result = s21_strlen(str1);
size_t result_etalon = strlen(str1);
ck_assert_uint_eq(result, result_etalon);